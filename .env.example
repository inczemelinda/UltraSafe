POSTGRES_HOST=localhost
POSTGRES_DB=underwright
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

UNDERWRIGHT_CLAIM_UPLOAD_DIR=/tmp/underwright-claim-uploads
UNDERWRIGHT_CLAIM_UPLOAD_MAX_BYTES=10485760
UNDERWRIGHT_CLAIM_DOCUMENT_DEMO_EXTRACTION=false

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_SECONDS=15
INTELLIGENCE_AI_SUMMARIES_ENABLED=false
INTELLIGENCE_SUMMARY_MODEL=gpt-4o-mini

POSTMARK_SERVER_TOKEN=your_postmark_server_token_here
EMAIL_SMTP_HOST=smtp.postmarkapp.com
EMAIL_SMTP_PORT=587
EMAIL_FROM=no-reply@ultrasafe.ro
EMAIL_DEMO_CLAIM_DECISION_TO=claims-demo@ultrasafe.ro
EMAIL_TEST_TO=client@test.com
CLAIM_INBOUND_EMAIL_ADDRESS=claims@inbound.ultrasafe.example
CLAIM_INBOUND_EMAIL_DOMAIN=inbound.ultrasafe.example
POSTMARK_WEBHOOK_USERNAME=postmark-webhook-user
POSTMARK_WEBHOOK_PASSWORD=postmark-webhook-password

VITE_API_BASE_URL=http://localhost:8000
VITE_USE_MOCK_API=false
VITE_BACKEND_PRICING=true
